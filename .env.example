# Environment Variables for Telegram Multi-Instance Manager

# A strong random secret token — used by the front-end login and Public API Bearer auth
ACCESS_TOKEN=change_me_to_a_strong_secret

# Server port
PORT=3000

# Public URL of this instance (used to generate absolute links for webhooks, e.g. media downloads)
PUBLIC_URL=http://localhost:3000

# PostgreSQL database URL (used locally, Docker Compose overwrites this for the container)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/telegram_multi_instance_manager?schema=public"

# Telegram API credentials — get them at https://my.telegram.org
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
